{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "declaration": true,
    "rootDir": ".",
    "outDir": "dist",
    "strict": true,
    "types": ["node", "vitest"],
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true
  },
  "include": ["src/**/*", "bin/**/*"],
  "ts-node": {
    "preferTs": true,
    "transpileOnly": true
  }
}
