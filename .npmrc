# ==============================================================================
# .NPMRC CONFIGURATION FILE
# ==============================================================================

# Automatically runs a security scan for known vulnerabilities every time 
# you run 'npm install' to keep your project safe.
audit=true

# Hides the annoying "X packages are looking for funding" messages 
# after installations, keeping your terminal output clean.
fund=false

# Validates your local Node.js version against the one specified in package.json. 
# If they don't match, it blocks the installation to prevent unexpected environment bugs.
engine-strict=true

# [pnpm exclusive] Prevents installing packages that are less than 3 days old 
# to avoid zero-day malware. If run with npm, this line is simply ignored.
minimum-release-age=4320

# [pnpm/yarn exclusive] Blocks direct installations from Git URLs. 
# If run with npm, this line is ignored and normal Git links will still work.
allow-git=none

# Forces the automatic installation of "peerDependencies" (companion libraries 
# that a package needs to work, like React) if you haven't added them yourself.
auto-install-peers=true

# Relaxes version conflicts for companion libraries. If there is a slight version 
# mismatch, it displays a warning in the terminal but lets you install anyway.
strict-peer-dependencies=false
